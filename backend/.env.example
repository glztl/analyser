# 应用配置
DEBUG=True

# 数据库 (请替换为你的腾讯云 PostgreSQL 地址)
DATABASE_URL=postgresql://user:password@your_tencent_ip:5432/analyser_db

# Redis (请替换为你的腾讯云 Redis 地址)
REDIS_URL=redis://your_tencent_ip:6379

# LLM 配置
LLM_API_KEY=sk-your-api-key
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1 # 支持兼容 OpenAI 接口的其他模型
LLM_MAX_TOKENS=4096
AGENT_MAX_RETRIES=3

# 安全密钥 (生产环境请使用 openssl rand -hex 32 生成)
SECRET_KEY=super-secret-key-change-me

# 文件存储配置
UPLOAD_DIR=./uploads
SANDBOX_OUTPUT_DIR=./outputs
ALLOWED_EXTENSIONS=.csv,.xlsx,.xls
MAX_FILE_SIZE=10485760